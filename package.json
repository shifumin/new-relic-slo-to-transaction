{
  "name": "new-relic-slo-to-transaction",
  "description": "Jump from a New Relic SLO summary page to the APM transaction detail it monitors, with one keyboard shortcut.",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "postinstall": "wxt prepare",
    "test": "vitest"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "happy-dom": "^20.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "wxt": "^0.20.17"
  }
}
